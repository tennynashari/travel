# Production Environment Variables untuk Systemd
# Copy file ini ke /etc/travel-backend/environment atau sesuaikan path

# Node Environment
NODE_ENV=production

# Server Configuration
PORT=5000
HOST=0.0.0.0

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/travel_db

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here-change-this
JWT_EXPIRES_IN=7d

# CORS Configuration (optional)
CORS_ORIGIN=https://yourdomain.com

# Upload Configuration (optional)
UPLOAD_DIR=/var/www/travel/uploads
MAX_FILE_SIZE=5242880

# Logging (optional)
LOG_LEVEL=info
LOG_FILE=/var/log/travel-backend/app.log

# Email Configuration (jika ada)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# API Keys (jika ada)
# MIDTRANS_SERVER_KEY=your-midtrans-key
# MIDTRANS_CLIENT_KEY=your-client-key
