// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OPERATOR
  DRIVER
  CUSTOMER
}

enum BookingStatus {
  PENDING
  PAID
  CONFIRMED
  CANCELLED
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

enum DriverStatus {
  ACTIVE
  OFF_DUTY
  INACTIVE
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      UserRole @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  bookings  Booking[]
  driver    Driver?

  @@map("users")
}

model City {
  id          String   @id @default(uuid())
  name        String
  province    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  routesFrom  Route[] @relation("RouteOrigin")
  routesTo    Route[] @relation("RouteDestination")

  @@map("cities")
}

model Route {
  id              String   @id @default(uuid())
  originCityId    String
  destinationCityId String
  distance        Int      // in kilometers
  estimatedTime   Int      // in minutes
  basePrice       Int      // in rupiah
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  originCity      City     @relation("RouteOrigin", fields: [originCityId], references: [id])
  destinationCity City     @relation("RouteDestination", fields: [destinationCityId], references: [id])
  schedules       Schedule[]

  @@map("routes")
}

model SeatTemplate {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  rowsConfig  Json     // Array of seats per row, e.g., [2, 2, 2, 2, 2, 2]
  totalSeats  Int
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  vehicles    Vehicle[]

  @@map("seat_templates")
}

model Vehicle {
  id             String        @id @default(uuid())
  plateNumber    String        @unique
  vehicleType    String
  capacity       Int
  seatTemplateId String?
  status         VehicleStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  seatTemplate   SeatTemplate?  @relation(fields: [seatTemplateId], references: [id])
  schedules      Schedule[]

  @@map("vehicles")
}

model Driver {
  id        String       @id @default(uuid())
  userId    String       @unique
  licenseNumber String   @unique
  status    DriverStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // Relations
  user      User         @relation(fields: [userId], references: [id])
  schedules Schedule[]

  @@map("drivers")
}

model Schedule {
  id              String   @id @default(uuid())
  routeId         String
  vehicleId       String
  driverId        String
  departureDate   DateTime
  departureTime   String
  ticketPrice     Int
  availableSeats  Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  route           Route    @relation(fields: [routeId], references: [id])
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])
  driver          Driver   @relation(fields: [driverId], references: [id])
  bookings        Booking[]

  @@map("schedules")
}

model Booking {
  id            String        @id @default(uuid())
  bookingCode   String        @unique
  userId        String
  scheduleId    String
  seatNumbers   String[]      // Array of seat numbers
  totalSeats    Int
  totalPrice    Int
  status        BookingStatus @default(PENDING)
  paymentMethod String?
  paidAt        DateTime?
  checkedIn     Boolean       @default(false)
  checkInTime   DateTime?
  checkInBy     String?       // User ID who performed check-in
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  user          User          @relation(fields: [userId], references: [id])
  schedule      Schedule      @relation(fields: [scheduleId], references: [id])

  @@map("bookings")
}
